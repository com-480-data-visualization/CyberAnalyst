            "import plotly.express as px\n",
            "\n",
            "# load je-e-19.02.09.01.03.xlsx\n",
            "import pandas as pd\n",
            "swissData = pd.read_excel('../Dataset/je-e-19.02.09.01.03.xlsx',header=3)\n",
            "\n",
            "swissData.head()\n",
            "\n",
            "age_ranges = [swissData.columns[0]] + swissData.columns[7:18].tolist()\n",
            "age_data = swissData[age_ranges][:36]\n",
            "age_data = age_data.rename(columns={age_data.columns[0]: 'Attack_Type'})\n",
            "\n",
            "# For each attack type, calculate the percentage distribution across age groups\n",
            "age_percentages = age_data.copy()\n",
            "for i in range(1, len(age_data.columns)):\n",
            "    age_percentages[age_data.columns[i]] = age_data[age_data.columns[i]] / age_data[age_data.columns[1:]].sum(axis=1)\n",
            "\n",
            "# Reshape for Plotly\n",
            "age_percentages_melted = age_percentages.melt(id_vars='Attack_Type', var_name='Age_Group', value_name='Percentage')\n",
            "\n",
            "\n",
            "\n"
        ]
