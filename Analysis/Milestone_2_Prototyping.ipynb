            "import plotly.graph_objects as go\n",
            "import pandas as pd\n",
            "\n",
            "# ------------------------------------------------------------\n",
            "# POC 1: Switzerland cybercrime structure (network-style graph)\n",
            "# ------------------------------------------------------------\n",
            "# Placeholder hierarchy and values (replace with real counts later)\n",
            "nodes = [\n",
